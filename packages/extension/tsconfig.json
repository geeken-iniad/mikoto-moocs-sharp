{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@mikoto-moocs-sharp/shared": ["../shared/src/index.ts"],
      "@mikoto-moocs-sharp/shared/notification": [
        "../shared/src/notification/index.ts"
      ],
      "@mikoto-moocs-sharp/shared/schedule": [
        "../shared/src/schedule/index.ts"
      ],
      "@mikoto-moocs-sharp/shared/settings": [
        "../shared/src/settings/index.ts"
      ],
      "@mikoto-moocs-sharp/shared/storage": ["../shared/src/storage/index.ts"],
      "@mikoto-moocs-sharp/shared/styles/*": ["../shared/src/styles/*"],
      "@mikoto-moocs-sharp/shared/types": ["../shared/src/types/index.ts"],
      "@mikoto-moocs-sharp/shared/ui": ["../shared/src/ui/index.ts"]
    }
  },
  "include": [".wxt/**/*", "entrypoints/**/*"]
}
