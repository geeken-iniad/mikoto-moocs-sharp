{
  "name": "mikoto-moocs-sharp",
  "description": "MOOCsをより便利に - Monorepo",
  "license": "MIT",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.20.0",
    "pnpm": ">=10.18.3"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion@<=5.0.0": "5.0.1",
      "brace-expansion@<1.1.13": "1.1.13",
      "defu@<=6.1.4": "6.1.5",
      "immutable@>=5.0.0 <5.1.5": "5.1.5",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=10.0.0 <10.2.3": "10.2.3",
      "node-forge": "1.4.0",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "postcss@<8.5.10": "8.5.10",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "vite@>=7.0.0 <=7.3.1": "7.3.2"
    }
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev:extension": "pnpm --filter @mikoto-moocs-sharp/extension dev",
    "dev:userscript-pro": "pnpm --filter @mikoto-moocs-sharp/userscript-pro dev",
    "dev:userscript-lite": "pnpm --filter @mikoto-moocs-sharp/userscript-lite dev",
    "dev:extension:firefox": "pnpm --filter @mikoto-moocs-sharp/extension dev:firefox",
    "check:boundaries": "depcruise --config .dependency-cruiser.cjs --output-type err packages",
    "check:biome": "biome ci .",
    "test": "vitest run --passWithNoTests",
    "build:extension": "pnpm --filter @mikoto-moocs-sharp/extension build",
    "build:userscript-pro": "pnpm --filter @mikoto-moocs-sharp/userscript-pro build",
    "build:userscript-lite": "pnpm --filter @mikoto-moocs-sharp/userscript-lite build",
    "build:all": "pnpm -r build",
    "compile": "pnpm -r compile"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.5",
    "dependency-cruiser": "^17.4.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.5"
  }
}
